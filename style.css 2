/* =========================
   HERO SECTION
========================= */

.hero {
    padding: 80px 0;
    background: linear-gradient(135deg, #eaf4ff, #ffffff);
}

.hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
}

.tagline {
    display: inline-block;
    color: #2b7de9;
    font-weight: 600;
    margin-bottom: 10px;
}

.hero h1 {
    font-size: 40px;
    line-height: 1.2;
    margin-bottom: 15px;
}

.hero p {
    margin-bottom: 20px;
    color: #4a5a6a;
}

.hero-buttons {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

/* =========================
   SECTIONS GENERAL
========================= */

section {
    padding: 70px 0;
}

.section-title {
    text-align: center;
    margin-bottom: 40px;
}

.section-title span {
    color: #2b7de9;
    font-weight: 600;
}

.section-title h2 {
    font-size: 28px;
    margin-top: 5px;
}

/* =========================
   CARDS
========================= */

.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 25px;
}

.card {
    background: #fff;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-5px);
}

.card-content {
    padding: 15px;
}

.card h3 {
    margin-bottom: 10px;
}

/* =========================
   ABOUT GRID
========================= */

.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
}

/* =========================
   GALLERY
========================= */

.gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 10px;
}

.gallery-grid img {
    border-radius: 8px;
    transition: 0.3s;
}

.gallery-grid img:hover {
    transform: scale(1.03);
}

/* =========================
   CTA
========================= */

.cta {
    background: #2b7de9;
    color: #fff;
    text-align: center;
}

.cta-box p {
    margin: 10px 0 20px;
}

/* =========================
   CONTACT
========================= */

.contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
}

.contact-form {
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.contact-form input,
.contact-form textarea {
    padding: 12px;
    border: 1px solid #ddd;
    border-radius: 6px;
    outline: none;
}

.contact-form textarea {
    min-height: 120px;
}

/* =========================
   FOOTER
========================= */

.footer {
    background: #1b2b3a;
    color: #fff;
    padding: 50px 0 20px;
}

.footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
}

.footer h4, .footer h3 {
    margin-bottom: 10px;
}

.footer ul {
    list-style: none;
}

.footer ul li {
    margin-bottom: 8px;
    color: #cfd8e3;
}

.footer-bottom {
    text-align: center;
    margin-top: 30px;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 15px;
}

/* =========================
   SCROLL TOP BUTTON
========================= */

.scroll-top {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #2b7de9;
    color: #fff;
    border: none;
    padding: 10px 15px;
    border-radius: 50%;
    display: none;
    cursor: pointer;
}

/* =========================
   FADE ANIMATION
========================= */

.fade-section {
    opacity: 0;
    transform: translateY(30px);
    transition: 0.6s ease;
}

.fade-section.show {
    opacity: 1;
    transform: translateY(0);
}

/* =========================
   RESPONSIVE DESIGN
========================= */

@media (max-width: 768px) {

    .hero-grid,
    .about-grid,
    .contact-grid {
        grid-template-columns: 1fr;
    }

    .navbar {
        display: none;
        position: absolute;
        top: 70px;
        right: 0;
        background: #fff;
        width: 200px;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        padding: 20px;
    }

    .navbar ul {
        flex-direction: column;
    }

    .menu-btn {
        display: block;
    }
  }
